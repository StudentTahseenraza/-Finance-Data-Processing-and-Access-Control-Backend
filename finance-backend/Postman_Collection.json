              "raw": "{\n    \"amount\": 5000.00,\n    \"type\": \"income\",\n    \"category\": \"Salary\",\n    \"date\": \"2024-04-01\",\n    \"description\": \"Monthly salary\",\n    \"notes\": \"April 2024 salary\",\n    \"tags\": [\"work\", \"monthly\"]\n}"
