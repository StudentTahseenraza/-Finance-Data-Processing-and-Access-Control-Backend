    {
      "name": "4. Role-Based Access Control Testing",
      "description": "Test what different roles can and cannot do",
      "item": [
        {
          "name": "[VIEWER] Try to Create Record (Should Fail - 403)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{viewerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"amount\": 100.00,\n    \"type\": \"expense\",\n    \"category\": \"Test\",\n    \"date\": \"2024-04-04\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/records",
              "host": ["{{baseUrl}}"],
              "path": ["records"]
            }
          }
        },
        {
          "name": "[VIEWER] Try to Delete Record (Should Fail - 403)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{viewerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/records/{{recordId}}",
              "host": ["{{baseUrl}}"],
              "path": ["records", "{{recordId}}"]
            }
          }
        },
        {
          "name": "[ANALYST] Create Record (Should Succeed - 201)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{analystToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"amount\": 200.00,\n    \"type\": \"expense\",\n    \"category\": \"Entertainment\",\n    \"date\": \"2024-04-04\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/records",
              "host": ["{{baseUrl}}"],
              "path": ["records"]
            }
          }
        }
      ]
